#!/usr/bin/env bash
# Memory + Changelog — git post-commit hook.
# 1. Extracts diff hunks directly into ChromaDB
# 2. Regenerates CHANGELOG.md for notable commit types

REPO_ROOT=$(git rev-parse --show-toplevel)
SCRIPTS="$REPO_ROOT/.agents/scripts"

# Pass 1 — extract hunks to Chroma (requires chromadb)
if [ -f "$SCRIPTS/extract_changes.py" ] && python3 -c "import chromadb" &>/dev/null; then
    python3 "$SCRIPTS/extract_changes.py" 2>/dev/null || true
fi

# Pass 2 — regenerate changelog for notable commits
COMMIT_MSG=$(git log -1 --format=%s)
COMMIT_TYPE=$(echo "$COMMIT_MSG" | grep -oE '^(feat|fix|refactor|perf|sec)' || true)
IS_CHGLOG=$(echo "$COMMIT_MSG" | grep -qE '^chore(\(changelog\))?' && echo 1 || true)

if [ -n "$COMMIT_TYPE" ] && [ -z "$IS_CHGLOG" ] && [ -f "$SCRIPTS/generate-changelog.py" ]; then
    SHORT=$(git log -1 --format=%h)
    python3 "$SCRIPTS/generate-changelog.py" 2>/dev/null
    if ! git diff --quiet "CHANGELOG.md" 2>/dev/null || ! git ls-files --error-unmatch "CHANGELOG.md" 2>/dev/null; then
        git add "CHANGELOG.md"
        git commit --no-verify -m "chore(changelog): update for $SHORT" 2>/dev/null && \
            echo "[changelog] CHANGELOG.md updated for $SHORT"
    fi
fi
